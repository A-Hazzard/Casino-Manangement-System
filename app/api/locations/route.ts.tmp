/**
 * Main GET handler for fetching locations
 */
export async function GET(request: NextRequest) {
  return withApiAuth(request, async ({ userRoles }) => {
    const { searchParams } = new URL(request.url);
    const licencee = searchParams.get('licencee');
    const minimal = searchParams.get('minimal') === '1';
    const forceAll = searchParams.get('forceAll') === 'true' || searchParams.get('forceAll') === '1';
    const showArchived = searchParams.get('archived') === 'true';

    const userAccessibleLicencees = await getUserAccessibleLicenceesFromToken();
    const normalizedUserRoles = userRoles.map(r => String(r).toLowerCase());
    const isAdminOrDeveloper = normalizedUserRoles.includes('admin') || normalizedUserRoles.includes('developer');

    // Use only new field
    const userPayload = (request as any).userPayload; // Injected by withApiAuth if we want, but we should use the one from withApiAuth params
    // Wait, withApiAuth doesn't inject the full user object yet, just session info?
    // Actually, I should check withApiAuth again.
    
    // For now, I'll use the userPayload from withApiAuth's context if I update it.
    // Actually, I'll just keep the original logic for permissions retrieval for now to be safe.
  });
}
